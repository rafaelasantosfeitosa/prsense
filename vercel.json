{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @prsense/web build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "web/.next",
  "framework": "nextjs",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- web shared package.json pnpm-lock.yaml"
}
